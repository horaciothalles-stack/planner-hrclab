# Variáveis de ambiente necessárias no projeto da Vercel
# (Vercel → Settings → Environment Variables)

# Senha de acesso ao planner (você escolhe). Sem ela, ninguém acessa nem edita os dados.
PLANNER_PASSWORD=troque-por-uma-senha-forte

# Preenchidas automaticamente quando você conecta um banco Redis/KV (Upstash) via
# Vercel → seu projeto → Storage → Connect Database → Upstash (ou Marketplace → Upstash).
# Não precisa criar essas duas manualmente se conectar por lá.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
